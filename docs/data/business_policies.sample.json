    {
      "policy_id": "region_context_default",
      "canonical": "region_context_default",
      "ko_label": "지역 표현 기본 해석",
      "description": "사용자가 '구매한 사람의 지역', '고객 지역'처럼 지역을 모호하게 말하면 기본적으로 고객 거주 지역 users.region으로 해석한다. 구매 장소, 매장 지역, 배송지처럼 구매 발생 위치를 명시하면 현재 스키마에 대응 컬럼이 없으므로 추가 확인을 요청한다.",
      "synonyms": [
        "지역",
        "고객 지역",
        "고객의 지역",
        "사람의 지역",
        "거주 지역",
        "사는 지역",
        "거주지",
        "구매한 사람의 지역"
      ],
      "scope": "semantic_resolution",
      "ambiguous_term": "지역",
      "default_resolution": "customer_residence_region",
      "default_column": "users.region",
      "default_select": "u.region",
      "sql_behavior": "disambiguation",
      "clarification_terms": [
        "구매한 곳",
        "구매 장소",
        "구매 지역",
        "매장 지역",
        "매장",
        "배송지",
        "배송 지역",
        "결제 지역"
      ],
      "clarification_question": "지역이 고객 거주 지역(users.region)을 의미하나요, 아니면 구매 장소/매장/배송지 지역을 의미하나요? 현재 스키마에는 구매 발생 지역 컬럼이 없습니다.",
      "alternatives": [
        {
          "meaning": "customer_residence_region",
          "column": "users.region",
          "available": true
        },
        {
          "meaning": "purchase_location_region",
          "column": null,
          "available": false,
          "requires_schema": true
        }
      ],
