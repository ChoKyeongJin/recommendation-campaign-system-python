    {
      "policy_id": "channel_message_generation",
      "canonical": "channel_message_generation",
      "ko_label": "채널 메시지 생성 정책",
      "description": "타겟팅 SQL이 성공한 이후 LMS 또는 RCS 발송 문안을 생성할 때 적용하는 기본 정책이다. 프롬프트에 채널이 없으면 LMS를 기본 채널로 사용하고, 캠페인 offer와 기존 메시지 예시 밖의 혜택을 만들지 않는다.",
      "synonyms": [
        "메시지 생성",
        "발송 문안",
        "채널 메시지",
        "LMS 메시지",
        "RCS 메시지",
        "message generation"
      ],
      "scope": "message_generation",
      "default_channel": "lms",
      "allowed_channels": ["lms", "rcs"],
      "channel_limits": {
        "lms": {
          "max_chars": 1000,
          "unit": "characters"
        },
        "rcs": {
          "max_chars": 1300,
          "unit": "characters"
        }
      },
      "required_variants": [
        "benefit_emphasis",
        "urgency_emphasis",
        "emotion_emphasis"
      ],
      "anti_hallucination": {
        "benefit_source_fields": [
          "campaigns.offer",
          "campaign_message_examples.message_text",
          "campaign_channel_messages.message_body",
          "campaign_message_variants.message_body"
        ],
        "deny_unverified_benefits": true
      },
      "sql_behavior": "context",
      "related_tables": [
        "campaigns",
        "campaign_channels",
        "campaign_message_examples",
        "campaign_channel_messages",
        "campaign_experiments",
        "campaign_message_variants",
        "campaign_message_deliveries",
