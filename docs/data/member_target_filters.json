  "campaign_response_targets": {
    "table": "MCS_CAMP_MBR_RSPN_FT",
    "alias": "R",
    "member_join": {
      "left": "TRY_CAST(R.MBR_NO AS BIGINT)",
      "right": "B.MEMBER_NO"
    },
    "campaign_join": {
      "table": "Z_CAMPAIGN",
      "alias": "ZC",
      "conditions": [
        "ZC.CAMP_ID = R.CAMP_ID",
        "ZC.CAMP_EXEC_NO = R.CAMP_EXEC_NO"
      ]
    },
    "target_group_condition": {
      "column": "R.CGRP_TYPE_CD",
      "value": "T"
    },
    "valid_campaign_condition": {
      "expression": "ISNULL(ZC.CANCEL_YN, 'N') = 'N'"
    },
    "boolean_metrics": {
      "contact_success": {
        "column": "R.CNCT_SCS_YN",
        "value": "Y",
        "synonyms": ["발송 성공", "접촉 성공", "메시지를 받은"]
      },
      "offer_response": {
        "column": "R.OFFR_RSPN_YN",
        "value": "Y",
        "synonyms": ["오퍼 반응", "혜택 반응", "쿠폰 반응"]
      },
      "purchase_response": {
        "column": "R.BUY_RSPN_YN",
        "value": "Y",
        "synonyms": ["캠페인 구매", "구매 반응", "캠페인 후 구매"]
      }
