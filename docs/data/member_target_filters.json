  "recent_login_target": {
    "column": "B.LAST_LOGIN_DATE",
    "table": "CRM_MB_BASEINFO",
    "alias": "B",
    "anchor": "getdate",
    "default_days": 30,
    "synonyms": ["최근 로그인", "최근 접속", "마지막 로그인"]
  },

  "region_target": {
    "table": "CRM_MB_BASEINFO",
    "alias": "B",
    "columns": {
      "sido": "B.SIDO",
      "sigungu": "B.SIGUNGU",
      "dong": "B.DONG",
      "zip_code": "B.ZIP_CD",
      "road_address": "B.ROAD_NAME_ADDRESS"
