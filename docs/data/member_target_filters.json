    "aggregate_metrics": {
      "cart_line_count": {
        "agg": "COUNT",
        "column": "C.CART_PRODUCT_NO",
        "distinct": true,
        "synonyms": ["장바구니 상품 종류", "장바구니 라인 수"]
      },
      "cart_quantity": {
        "agg": "SUM",
        "column": "C.SET_QTY",
        "synonyms": ["장바구니 수량", "담은 상품 개수"]
