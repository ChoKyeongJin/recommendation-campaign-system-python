          "카트 미결제",
          "장바구니 미구매"
        ]
      }
    },
    "cart_types": [
      {
        "canonical": "general_cart",
        "value": "CART_TYPE_CD.GENERAL",
        "synonyms": ["일반 장바구니", "일반 상품"]
      },
      {
        "canonical": "regular_delivery_cart",
        "value": "CART_TYPE_CD.REGULARDELIVERY",
        "synonyms": ["정기배송 장바구니", "정기배송 상품"]
