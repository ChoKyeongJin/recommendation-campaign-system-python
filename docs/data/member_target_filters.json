  "logical_expression_registry": {
    "and_tokens": ["그리고", "이면서", "동시에", "모두", "이며"],
    "or_tokens": ["또는", "혹은", "중 하나", "이거나"],
    "except_tokens": ["단", "제외하고", "빼고"],
