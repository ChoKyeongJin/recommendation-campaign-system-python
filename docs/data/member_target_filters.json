      "dong": ["동", "읍", "면", "동네"]
    }
  },

  "signup_store_target": {
    "table": "CRM_CM_OFFSHOP",
    "alias": "S",
    "join": {
      "type": "LEFT",
      "left": "B.REG_OFFSHOP_ID",
      "right": "S.OFFSHOP_ID"
    },
    "match_columns": [
      "S.OFFSHOP_ID",
      "S.OFFSHOP_NAME",
      "S.SIDO",
      "S.SIGUNGU",
      "S.DONG"
    ],
    "synonyms": ["가입 매장", "등록 매장", "가입 지점", "가입 점포"]
  },

  "order_count_targets": {
    "table": "CRM_SL_ORDERHEADERMALL",
    "alias": "OH",
    "join_column": "MEMBER_NO",
    "base_join_column": "B.MEMBER_NO",
    "order_id_column": "ORDER_ID",
    "order_date_column": "ORDER_DATE",
    "date_format": "yyyyMMdd",
    "default_period_days": null,
    "behaviors": {
      "first_purchase": {
        "operator": "=",
        "count": 1,
        "synonyms": ["첫 구매", "최초 구매", "한 번 구매"]
      },
      "repeat_buyer": {
        "operator": ">=",
        "count": 2,
        "synonyms": ["재구매", "반복 구매", "두 번 이상 구매"]
      },
      "no_purchase": {
        "anti_join": true,
        "synonyms": ["미구매", "구매 이력 없음", "한 번도 구매하지 않은"]
      },
      "lapsed_buyer": {
        "exists_before_period": true,
        "not_exists_in_period": true,
        "default_days": 90,
        "synonyms": ["이탈 구매자", "예전에는 구매했지만 최근 구매하지 않은"]
      }
    }
  },

  "aggregate_targets": {
    "table": "CRM_SL_ORDERHEADERMALL",
    "alias": "OH",
    "join_column": "MEMBER_NO",
    "base_join_column": "B.MEMBER_NO",
    "date_column": "ORDER_DATE",
    "date_format": "yyyyMMdd",
    "metrics": {
      "purchase_amount": {
        "agg": "SUM",
        "column": "PAYMENT_AMT",
        "null_as": 0,
        "ko_label": "누적 구매 금액",
        "synonyms": [
          "누적 구매 금액",
          "누적구매금액",
          "구매 금액",
          "구매금액",
          "결제 금액",
          "결제금액",
          "구매액",
          "구매 총액",
          "구매총액",
          "구매 총금액",
          "총 결제액"
        ]
      },
      "order_count": {
        "agg": "COUNT",
        "column": "ORDER_ID",
        "distinct": true,
        "null_as": 0,
        "ko_label": "구매 횟수",
        "synonyms": [
          "구매 횟수",
          "구매횟수",
          "주문 횟수",
          "주문횟수",
          "구매 건수",
          "구매건수",
          "주문 건수",
          "주문건수"
        ]
      },
      "average_order_amount": {
        "expression": "SUM(OH.PAYMENT_AMT) / NULLIF(COUNT(DISTINCT OH.ORDER_ID), 0)",
        "ko_label": "평균 주문 금액",
        "synonyms": ["평균 주문 금액", "객단가", "평균 결제 금액"]
      },
      "last_purchase_date": {
        "agg": "MAX",
        "column": "ORDER_DATE",
        "ko_label": "최근 구매일",
        "synonyms": ["최근 구매일", "마지막 구매일", "최종 주문일"]
      },
      "first_purchase_date": {
        "agg": "MIN",
        "column": "ORDER_DATE",
        "ko_label": "최초 구매일",
        "synonyms": ["최초 구매일", "첫 구매일", "처음 주문한 날짜"]
      }
    }
  },

  "purchase_product_target": {
    "order_header": {
      "table": "CRM_SL_ORDERHEADERMALL",
      "alias": "OH",
      "member_join": "OH.MEMBER_NO = B.MEMBER_NO"
    },
    "order_detail": {
      "table": "CRM_SL_ORDERDETAILMALL",
      "alias": "OD",
      "join": "OD.ORDER_ID = OH.ORDER_ID"
    },
    "product": {
      "table": "CRM_CM_PRODUCT",
      "alias": "P",
      "join": "P.PRODUCT_ID = OD.PRODUCT_ID"
    },
    "match_columns": [
      "P.CATEGORY",
      "P.CATEGORYL_NAME",
      "P.CATEGORYM_NAME",
