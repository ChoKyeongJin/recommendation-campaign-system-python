{
  "version": "1.1",
  "description": "회원 타겟 규칙 엔진 레지스트리. 회원 속성, 활동성, 동의, 지역, 가입, 로그인, 구매, 장바구니, 캠페인 반응 조건을 선언형으로 관리한다.",

  "base_entity": {
    "table": "CRM_MB_BASEINFO",
    "alias": "B",
    "member_key": "MEMBER_NO",
    "login_id_key": "MEMBER_ID",
    "date_format": "yyyyMMdd"
  },

  "default_policy": {
    "apply_active_member": true,
    "exclude_withdrawn": true,
    "exclude_blacklist": true,
    "exclude_site_only_member": false,
    "require_marketing_agreement": false,
    "null_boolean_as": "N",
    "distinct_member": true
  },

  "operator_registry": {
    "eq": {
      "sql": "=",
      "synonyms": ["인", "인 사람", "해당하는", "같은", "동일한"]
    },
    "neq": {
      "sql": "<>",
      "synonyms": ["아닌", "제외한", "빼고", "해당하지 않는"]
    },
    "gte": {
      "sql": ">=",
      "synonyms": ["이상", "최소", "넘는 또는 같은"]
    },
    "gt": {
      "sql": ">",
      "synonyms": ["초과", "넘는", "보다 큰"]
    },
    "lte": {
      "sql": "<=",
      "synonyms": ["이하", "최대", "넘지 않는"]
    },
    "lt": {
      "sql": "<",
      "synonyms": ["미만", "보다 적은", "안 되는"]
    },
    "between": {
      "sql": "BETWEEN",
      "synonyms": ["사이", "부터", "에서", "구간"]
    },
    "in": {
      "sql": "IN",
      "synonyms": ["중", "또는", "포함하는"]
    },
    "not_in": {
      "sql": "NOT IN",
      "synonyms": ["제외", "포함하지 않는"]
    }
  },

