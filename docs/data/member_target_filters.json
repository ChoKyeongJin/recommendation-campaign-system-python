    "alias": "C",
    "join": {
      "type": "EXISTS",
      "left": "C.CART_ID",
      "right": "B.MEMBER_ID"
    },
    "product_join": {
      "table": "CRM_CM_PRODUCT",
      "alias": "CP",
      "left": "C.PRODUCT_ID",
      "right": "CP.PRODUCT_ID"
    },
    "active_condition": {
      "column": "C.KEEP_YN",
      "value": "Y"
    },
    "cart_type_column": "C.CART_TYPE_CD",
    "product_id_column": "C.PRODUCT_ID",
    "quantity_column": "C.SET_QTY",
    "line_id_column": "C.CART_PRODUCT_NO",
    "behaviors": {
      "has_cart": {
        "exists": true,
        "synonyms": ["장바구니 보유", "장바구니에 상품이 있는", "카트에 담은"]
      },
      "no_cart": {
        "anti_join": true,
        "synonyms": ["장바구니가 없는", "카트가 비어 있는"]
      },
      "cart_abandoner": {
        "exists": true,
        "order_anti_join": true,
        "order_table": "CRM_SL_ORDERHEADERMALL",
        "order_member_column": "MEMBER_NO",
        "synonyms": [
          "장바구니 이탈",
